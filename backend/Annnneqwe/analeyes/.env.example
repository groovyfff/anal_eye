# ============================================================
# AnalEyes backend .env.example
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=analeyes
POSTGRES_PASSWORD=change_me
POSTGRES_DB=analeyes
DATABASE_URL=postgresql+asyncpg://analeyes:change_me@postgres:5432/analeyes


# --- RabbitMQ application user ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=analeyes
RABBITMQ_PASSWORD=change_me
RABBITMQ_PASS=change_me
RABBITMQ_VHOST=analeyes
RABBITMQ_URL=amqp://analeyes:change_me@rabbitmq:5672/analeyes
RABBITMQ_EXCHANGE=analeyes.events


# --- RabbitMQ Management UI ---
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASSWORD=change_me
RABBITMQ_MANAGEMENT_PORT=15672


# --- App runtime ---
PYTHONPATH=/app
API_SECRET_KEY=change_me
HEALTH_CHECK_TOKEN=change_me


# --- Binance API keys, optional for public market data ---
BINANCE_API_KEY=
BINANCE_API_SECRET=


# --- Binance Futures WebSocket live-price publisher ---
BINANCE_LIVE_ENABLED=true

SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
ANAL_EYES_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
SYMBOL_LIMIT=6
QUOTE_ASSET=USDT

BINANCE_TIMEFRAME=1h
BINANCE_MARKET=futures
BINANCE_WSS_BASE_URL=wss://fstream.binance.com/ws
BINANCE_RECONNECT_DELAY_SEC=5
BINANCE_PUBLISH_RAW_KLINE=true
BINANCE_LOG_EVERY_N=20


# --- Binance candidate publisher -> AE Brain ---
BINANCE_CANDIDATE_ENABLED=true
BINANCE_CANDIDATE_MIN_CANDLES=200
BINANCE_CANDIDATE_PUBLISH_MODE=closed_candle
BINANCE_CANDIDATE_THROTTLE_SEC=3600
BINANCE_CANDIDATE_PUBLISH_ON_CANDLE_CLOSE=true
BINANCE_CANDIDATE_PUBLISH_ON_EVERY_UPDATE=false
BINANCE_BOOTSTRAP_LIMIT=200
BINANCE_REST_BASE_URL=https://fapi.binance.com

CANDIDATE_TIMEFRAME=1h
CANDIDATE_CLOSED_CANDLES_ONLY=true
CANDIDATE_DEDUP_ENABLED=true
CANDIDATE_MIN_INTERVAL_SEC=3600
CANDIDATE_WINDOW_CANDLES=200
CANDIDATE_BACKFILL_PUBLISH_HISTORICAL=false
ENABLE_LEGACY_PARSER=false
ENABLE_HIGH_FREQUENCY_TEST_PARSER=false
BINANCE_MARKET=usdm_futures

CANDIDATE_REST_FALLBACK_ENABLED=true
CANDIDATE_REST_FALLBACK_POLL_SEC=60
CANDIDATE_REST_FALLBACK_ALWAYS_ON=true
CANDIDATE_WS_IDLE_TIMEOUT_SEC=60

CANDIDATE_CONTINUOUS_TEST_MODE=false
CANDIDATE_EMIT_INTERVAL_MS=3600000
CANDIDATE_EMIT_ROUND_ROBIN=false
CANDIDATE_EMIT_REQUIRE_MIN_CANDLES=true
CANDIDATE_DEDUP_DB_PATH=/app/data/candidate_dedup.db


# --- Telegram notification-service ---
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_ADMIN_ID=change_me
TELEGRAM_GROUP_ID=change_me
TELEGRAM_SEND_INTERVAL_MS=200
TELEGRAM_ALLOW_NO_TOPIC=false

NOTIFICATION_SEND_SKIPPED_DECISIONS=false
NOTIFICATION_DISABLE_DEDUP_IN_TEST_MODE=false
NOTIFICATION_MIN_CONFIDENCE=0.70


# --- AI providers, optional legacy keys ---
OPENAI_API_KEY=
GROK_API_KEY=
GROK3_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

X_BEARER_TOKEN=
HTTP_PROXY=
HTTPS_PROXY=

DATA_PROVIDER_API_KEY=your_api_key_here


# --- ai-service legacy behavior ---
AI_ACCEPT_MANUAL_TEST_CANDIDATES=true
AI_SERVICE_CONSUME_CANDIDATES=false


# ============================================================
# News service runtime
# ============================================================

NEWS_SERVICE_ENABLED=true
NEWS_PARSER_ENABLED=true
NEWS_ANALYZER_ENABLED=true
NEWS_RABBIT_ENABLED=true
NEWS_RAG_ENABLED=true


# ============================================================
# OpenRouter / Grok
# ============================================================

LLM_PROVIDER=openrouter

NEWS_LLM_PROVIDER=openrouter
NEWS_LLM_BASE_URL=https://openrouter.ai/api/v1
NEWS_LLM_MODEL=x-ai/grok-4.3

OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=x-ai/grok-4.3
OPENROUTER_TIMEOUT_SEC=30
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BACKOFF_SEC=5


# ============================================================
# Telegram signal presentation (notification-service)
# ============================================================

SIGNAL_PRESENTATION_LLM_ENABLED=true
SIGNAL_PRESENTATION_PROVIDER=openrouter
SIGNAL_PRESENTATION_MODEL=x-ai/grok-4.3
SIGNAL_PRESENTATION_BASE_URL=https://openrouter.ai/api/v1
SIGNAL_PRESENTATION_API_KEY=
SIGNAL_PRESENTATION_TIMEOUT_SEC=15
SIGNAL_PRESENTATION_MAX_RETRIES=2
SIGNAL_PRESENTATION_MAX_COMMENT_CHARS=220


# ============================================================
# News market signal -> AE Brain
# ============================================================

NEWS_ANALYSIS_ENABLED=true
NEWS_SIGNAL_ENABLED=true
NEWS_SIGNAL_EXCHANGE=analeyes.events
NEWS_SIGNAL_ROUTING_KEY=news.market_signal
NEWS_SIGNAL_QUEUE=q_news_market_signal
NEWS_MIN_RELEVANCE=0.65
NEWS_MIN_CONFIDENCE=0.50


# ============================================================
# Multi-source news/social parser
# ============================================================

# --- RSS ---
NEWS_RSS_ENABLED=true
NEWS_RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed
NEWS_RSS_ITEM_LIMIT=5
NEWS_PARSER_INTERVAL_S=300


# --- Generic HTML news sites ---
NEWS_HTML_ENABLED=true
NEWS_HTML_SOURCES=https://www.coindesk.com/,https://cointelegraph.com/,https://decrypt.co/
NEWS_HTML_ITEM_LIMIT=10


# --- Reddit public JSON ---
NEWS_REDDIT_ENABLED=true
NEWS_REDDIT_SUBREDDITS=CryptoCurrency,Bitcoin,ethereum,solana,binance,dogecoin,Ripple
NEWS_REDDIT_LIMIT=25


# --- StockTwits ---
NEWS_STOCKTWITS_ENABLED=true
NEWS_STOCKTWITS_SYMBOLS=BTC.X,ETH.X,SOL.X,BNB.X,XRP.X,DOGE.X
NEWS_STOCKTWITS_LIMIT=25


# --- Forums ---
NEWS_FORUM_ENABLED=true
NEWS_FORUM_URLS=https://bitcointalk.org/index.php?board=1.0,https://www.tradingview.com/ideas/bitcoin/,https://www.tradingview.com/ideas/ethereum/,https://www.tradingview.com/ideas/solana/
NEWS_FORUM_ITEM_LIMIT=20


# --- VIP watchlist ---
NEWS_VIP_ENABLED=true
NEWS_VIP_PEOPLE=elonmusk,realDonaldTrump,cz_binance,VitalikButerin
NEWS_VIP_TWITTER_USERS=elonmusk,realDonaldTrump,cz_binance,VitalikButerin
NEWS_VIP_TELEGRAM_CHANNELS=
NEWS_VIP_RSS_FEEDS=
NEWS_VIP_ITEM_LIMIT=20


# --- X / Twitter public parser ---
NEWS_TWITTER_ENABLED=true
NEWS_TWITTER_USERS=elonmusk,realDonaldTrump,cz_binance,VitalikButerin,APompliano,balajis,aantonop
NEWS_TWITTER_QUERY_TERMS=bitcoin,btc,ethereum,eth,solana,sol,xrp,bnb,doge,crypto,ETF,Fed,inflation,war,hack,SEC,Binance,Coinbase
NEWS_TWITTER_STORAGE_STATE=
NEWS_TWITTER_ITEM_LIMIT=20


# --- Telegram public channels through Telethon ---
NEWS_TELEGRAM_ENABLED=true
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=/data/telethon.session
NEWS_TELEGRAM_CHANNELS=binance_announcements,cointelegraph,coindesk,watcherGuru,whale_alert
NEWS_TELEGRAM_ITEM_LIMIT=30


# --- Source runtime limits / dedup ---
NEWS_SOURCE_TIMEOUT_SEC=20
NEWS_SOURCE_MAX_RETRIES=3
NEWS_SOURCE_RETRY_BACKOFF_SEC=5
NEWS_SOURCE_MIN_INTERVAL_SEC=30
NEWS_SOURCE_GLOBAL_CONCURRENCY=3
NEWS_SOURCE_STATE_DB_PATH=/data/news_sources_state.db

# --- Telegram signal presentation ---
SIGNAL_PRESENTATION_LLM_ENABLED=true
SIGNAL_PRESENTATION_PROVIDER=openrouter
SIGNAL_PRESENTATION_MODEL=x-ai/grok-4.3
SIGNAL_PRESENTATION_BASE_URL=https://openrouter.ai/api/v1
SIGNAL_PRESENTATION_API_KEY=
SIGNAL_PRESENTATION_TIMEOUT_SEC=15
SIGNAL_PRESENTATION_MAX_RETRIES=2
SIGNAL_PRESENTATION_MAX_COMMENT_CHARS=220
