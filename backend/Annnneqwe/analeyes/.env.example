# AnalEyes / AnalEyes_Crypto_V6 environment template — copy to .env via ./setup-env.sh

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=analeyes
POSTGRES_PASSWORD=analeyes
POSTGRES_DB=analeyes
DATABASE_URL=postgresql+asyncpg://analeyes:analeyes@postgres:5432/analeyes

# RabbitMQ application user (vhost analeyes) — NOT guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=analeyes
RABBITMQ_PASSWORD=analeyes_dev_secret
RABBITMQ_PASS=analeyes_dev_secret
RABBITMQ_VHOST=analeyes
RABBITMQ_URL=amqp://analeyes:analeyes_dev_secret@rabbitmq:5672/analeyes
RABBITMQ_EXCHANGE=analeyes.events

# RabbitMQ Management UI (bootstrap only)
RABBITMQ_ADMIN_USER=admin
RABBITMQ_ADMIN_PASSWORD=changeme
RABBITMQ_MANAGEMENT_PORT=15672

PYTHONPATH=/app

API_SECRET_KEY=change_me
HEALTH_CHECK_TOKEN=change_me

BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Futures WebSocket live-price publisher (binance-live-price-service)
BINANCE_LIVE_ENABLED=true
BINANCE_SYMBOLS=BTCUSDT
BINANCE_TIMEFRAME=1h
BINANCE_MARKET=futures
BINANCE_WSS_BASE_URL=wss://fstream.binance.com/ws
BINANCE_RECONNECT_DELAY_SEC=5
BINANCE_PUBLISH_RAW_KLINE=true
BINANCE_LOG_EVERY_N=20

# Binance candidate publisher (binance-candidate-service) -> AE Brain
BINANCE_CANDIDATE_ENABLED=true
BINANCE_CANDIDATE_MIN_CANDLES=100
BINANCE_CANDIDATE_PUBLISH_MODE=throttled
BINANCE_CANDIDATE_THROTTLE_SEC=60
BINANCE_CANDIDATE_PUBLISH_ON_CANDLE_CLOSE=true
BINANCE_CANDIDATE_PUBLISH_ON_EVERY_UPDATE=false
BINANCE_BOOTSTRAP_LIMIT=200
BINANCE_REST_BASE_URL=https://fapi.binance.com

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_GROUP_ID=
# Send to group main chat when ai_specific_topics has no mapping (no message_thread_id)
TELEGRAM_ALLOW_NO_TOPIC=false

OPENAI_API_KEY=
GROK_API_KEY=
GROK3_API_KEY=
GEMINI_API_KEY=
QWEN_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

X_BEARER_TOKEN=
HTTP_PROXY=
HTTPS_PROXY=

DATA_PROVIDER_API_KEY=your_api_key_here

# ai-service: accept manual RabbitMQ test candidates without DB row / signal_id
AI_ACCEPT_MANUAL_TEST_CANDIDATES=false
# ai-service is behind profile legacy-ai; AE Brain consumes candidates by default
AI_SERVICE_CONSUME_CANDIDATES=false
