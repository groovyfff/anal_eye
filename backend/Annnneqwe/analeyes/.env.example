# AnalEyes monorepo environment template — copy to .env and fill in secrets.

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=analeyes
POSTGRES_PASSWORD=analeyes
POSTGRES_DB=analeyes

DATABASE_URL=postgresql+asyncpg://analeyes:analeyes@postgres:5432/analeyes

RABBITMQ_USER=user
RABBITMQ_PASS=password
RABBITMQ_URL=amqp://user:password@rabbitmq:5672/

DATA_PROVIDER_API_KEY=your_api_key_here
