# Copy to `.env` and adjust. docker-compose reads this automatically.
# These defaults match the docker-compose service names/credentials.

AEB_ENV=dev
AEB_LOG_JSON=true

# --- PostgreSQL ---
AEB_DB_USER=ae_brain
AEB_DB_PASSWORD=ae_brain
AEB_DB_NAME=ae_brain
AEB_DB_PORT=5432

# --- RabbitMQ ---
AEB_AMQP_USER=guest
AEB_AMQP_PASS=guest
AEB_AMQP_PORT=5672
AEB_AMQP_UI_PORT=15672

# --- GPU (4x Tesla P100) ---
NVIDIA_VISIBLE_DEVICES=all

# --- Risk (override as needed) ---
AEB_RISK_ACCOUNT_EQUITY_USD=100000
AEB_RISK_MAX_LEVERAGE=5
AEB_RISK_KELLY_FRACTION=0.25
