# Copy to `.env` and adjust. docker-compose reads this automatically.

AEB_ENV=dev
AEB_LOG_JSON=true
AEB_DB_HOST=aeb-postgres
AEB_DB_USER=ae_brain
AEB_DB_PASSWORD=ae_brain
AEB_DB_NAME=ae_brain
AEB_DB_PORT=5432

# --- Main AnalEyes RabbitMQ (vhost analeyes, NOT guest/) ---
# Password must match backend/Annnneqwe/analeyes/.env RABBITMQ_PASSWORD
RABBITMQ_APP_PASSWORD=analeyes_dev_secret
AEB_AMQP_HOST=rabbitmq

AEB_INPUT_AMQP_URL=amqp://analeyes:analeyes_dev_secret@rabbitmq:5672/analeyes
AEB_OUTPUT_AMQP_URL=amqp://analeyes:analeyes_dev_secret@rabbitmq:5672/analeyes
AEB_INPUT_EXCHANGE=analeyes.events
AEB_INPUT_QUEUE=q_data_candidates_ai
AEB_INPUT_ROUTING_KEY=data.candidates.ai
AEB_OUTPUT_EXCHANGE=analeyes.events
AEB_OUTPUT_ROUTING_KEY=signal.final

AEB_ALLOW_LEGACY_GUEST_VHOST=false
AEB_DIRECT_TELEGRAM_ENABLED=false
AEB_PUBLISH_SKIPPED_DECISIONS=false
AEB_DISABLE_SIGNAL_DEDUP_IN_TEST_MODE=false

# Multi-asset universe (commit 6d60639 test_dynamic_symbols.py) + publish gate
# Internal inference accepts all symbols in this list; Telegram/signal.final
# publishes LONG/SHORT only when confidence >= AEB_MIN_PUBLISH_CONFIDENCE (0.70).
AEB_ONLY_BTC=false
AEB_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT
AEB_MIN_PUBLISH_CONFIDENCE=0.70

# --- News sentiment features (RabbitMQ-only, echo-only) ---
# AE Brain consumes data.news.sentiment snapshots published by
# news-sentiment-service. Disabled by default. When enabled, the latest fresh
# snapshot per symbol is attached to candidate.meta for echo/logging.
# NOTE: AE Brain re-derives scoring features from candles, so this does NOT yet
# change trade decisions; fusion-layer wiring is the documented next step.
AEB_ENABLE_NEWS_FEATURES=false
# Defaults to AEB_INPUT_AMQP_URL when empty (same broker as candidates).
AEB_NEWS_AMQP_URL=
AEB_NEWS_FEATURES_EXCHANGE=analeyes.events
AEB_NEWS_FEATURES_QUEUE=q_data_news_sentiment
AEB_NEWS_FEATURES_ROUTING_KEY=data.news.sentiment
AEB_NEWS_FEATURES_MAX_AGE_S=300

# --- Optional news.market_signal fusion (OpenRouter path) ---
# Consumes per-item news market signals (score 1-10) from news-sentiment-service
# and applies a BOUNDED confidence/EV nudge to LONG/SHORT signals. Optional and
# fail-closed: with no news, a down broker, or a malformed message, AE Brain
# behaves exactly as before (market-data-only inference). SKIP is never changed.
AEB_NEWS_SIGNAL_ENABLED=true
AEB_NEWS_SIGNAL_EXCHANGE=analeyes.events
AEB_NEWS_SIGNAL_QUEUE=q_news_market_signal
AEB_NEWS_SIGNAL_ROUTING_KEY=news.market_signal
AEB_NEWS_SIGNAL_TTL_SEC=21600
AEB_NEWS_MAX_CONF_DELTA=0.05
AEB_NEWS_MAX_EV_MULTIPLIER_DELTA=0.10
AEB_NEWS_MIN_RELEVANCE=0.65
# Defaults to AEB_INPUT_AMQP_URL when empty (same broker as candidates).
AEB_NEWS_SIGNAL_AMQP_URL=


# --- Optional local-only RabbitMQ (profile: local-mq) ---
# RABBITMQ_ADMIN_USER=admin
# RABBITMQ_ADMIN_PASSWORD=changeme
# AEB_INPUT_AMQP_URL=amqp://analeyes:changeme@rabbitmq:5672/analeyes
# AEB_OUTPUT_AMQP_URL=amqp://analeyes:changeme@rabbitmq:5672/analeyes

# --- GPU (4x Tesla P100) ---
NVIDIA_VISIBLE_DEVICES=all

# --- Risk (override as needed) ---
AEB_RISK_ACCOUNT_EQUITY_USD=100000
AEB_RISK_MAX_LEVERAGE=5
AEB_RISK_KELLY_FRACTION=0.25
